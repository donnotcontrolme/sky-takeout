<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.SetmealMapper">

<!--添加套餐-->
    <insert id="add" useGeneratedKeys="true" keyProperty="id">
        insert into setmeal
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">category_id,</if>
            <if test="name != null">name,</if>
            <if test="price != null">price,</if>
            <if test="status != null">status,</if>
            <if test="description != null">description,</if>
            <if test="image != null">image,</if>
            <if test="createTime != null">create_time,</if>
            <if test="createUser != null">create_user,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="updateUser != null">update_user</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="categoryId != null">#{categoryId},</if>
            <if test="name != null">#{name},</if>
            <if test="price != null">#{price},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            <if test="image != null">#{image},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="createUser != null">#{createUser},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="updateUser != null">#{updateUser},</if>
        </trim>
    </insert>

    <!--    分页查询套餐-->
    <select id="pageQuery" resultType="com.sky.vo.SetmealVO">
        select s.*,c.name categoryName from setmeal s left join category c
        on s.category_id = c.id
        <where>
            <if test="categoryId!=null">and s.category_id=#{categoryId}</if>
            <if test="name!=null">and s.name like concat('%',#{name},'%')</if>
            <if test="status!=null">and s.status=#{status}</if>
        </where>
    </select>

    <!--    根据id查询套餐-->
    <select id="getById" resultType="com.sky.entity.Setmeal">
        select s.*,c.name categoryName from setmeal s left join category c
        on s.category_id = c.id
        where s.id=#{id}
    </select>

    <!--批量删除套餐-->
    <delete id="deletByIds">
        delete from setmeal where id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>
    
<!--    修改套餐-->
    <update id="update">
        update setmeal
        <set>
            <if test="name!=null">name=#{name},</if>
            <if test="price!=null">price=#{price},</if>
            <if test="status!=null">status=#{status},</if>
            <if test="description!=null">description=#{description},</if>
            <if test="image!=null">image=#{image},</if>
            <if test="updateTime!=null">update_time=#{updateTime},</if>
            <if test="updateUser!=null">update_user=#{updateUser},</if>
            <if test="categoryId!=null">category_id=#{categoryId},</if>
        </set>
        where id=#{id}
    </update>
</mapper>
